          "behavior_tags_on_select": [
            "premature_escalation"
          ],
          "next_node": "N2_entry_tense"
        },
        {
          "choice_id": "N1_C3",
          "text": "Offer to come back later if this is a bad time.",
          "dialogue_response": "Owner: \"Yeah honestly that\u2019d be better. We\u2019re buried.\"",
