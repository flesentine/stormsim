        {
          "choice_id": "N1_C1",
          "text": "Calmly introduce yourself and explain that this is a routine stormwater inspection.",
          "dialogue_response": "Owner: \"Today? Seriously? We\u2019re slammed right now. How long is this gonna take?\"",
          "score_delta": {
            "communication": 10
          },
          "behavior_tags_on_select": [],
          "next_node": "N2_entry"
        },
        {
          "choice_id": "N1_C2",
          "text": "State that you are there to conduct an inspection and need access now.",
          "dialogue_response": "Owner: \"Yeah, I figured that. I\u2019m asking how long you\u2019re gonna be in my shop.\"",
